rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Vehicles collection
    match /vehicles/{vehicleId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId || request.resource.data.userId);
    }

    // Documents (Read-only for users)
    match /documents/{documentId} {
      allow read: if isSignedIn();
      allow write: if false; // Only via backend
    }

    // Document Chunks (Read-only for users)
    match /document_chunks/{chunkId} {
      allow read: if isSignedIn();
      allow write: if false; // Only via backend
    }

    // Chat Messages
    match /chat_messages/{messageId} {
      allow read, write: if isSignedIn() && isOwner(request.resource.data.userId || resource.data.userId);
    }
  }
}
