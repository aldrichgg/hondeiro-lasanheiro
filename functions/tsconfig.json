{
    "compilerOptions": {
        "module": "commonjs",
        "noImplicitAny": true,
        "outDir": "lib",
        "sourceMap": true,
        "strict": true,
        "target": "es2020",
        "rootDir": "src",
        "skipLibCheck": true,
        "esModuleInterop": true
    },
    "compileOnSave": true,
    "include": [
        "src"
    ]
}